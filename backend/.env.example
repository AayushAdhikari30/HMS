# Copy to .env and fill in. Never commit the real .env.

PORT=8000
NODE_ENV=development
# Origin of the React app. Also used to build links inside outbound emails,
# so it must be the address users actually reach the app on.
CLIENT_URL=http://localhost:5173
APP_NAME=Dhulikhel Hospital

# ── Database ────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hms
DB_USER=root
DB_PASSWORD=

# ── Auth ────────────────────────────────────────────────────────────────
# Use two different long random strings, e.g. `openssl rand -hex 32`.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# ── Email (optional) ────────────────────────────────────────────────────
# Leave MAIL_HOST blank in development: emails are printed to the server
# console instead of being sent, and every flow still works end to end.
# For a real inbox, https://ethereal.email gives you throwaway SMTP creds.
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=no-reply@dhulikhel-hms.local
MAIL_FROM_NAME=Dhulikhel Hospital

# ── SMS (optional) ──────────────────────────────────────────────────────
# Same deal: unset means messages are logged, not sent. Only notifications
# passing `sendSmsAlso: true` use this at all.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
