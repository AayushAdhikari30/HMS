### HMS backend — end-to-end test flow
### Requires the "REST Client" VS Code extension (humao.rest-client).
### Click "Send Request" above each block, top to bottom, in order.
### Make sure `npm run dev` is running first, and you've run
### `node src/seed/createFirstAdmin.js` at least once if you don't have an admin yet.

@baseUrl = http://localhost:8000/api/v1/hms

### 0. Health check (sanity)
GET http://localhost:8000/health

###
### 1. Log in as ADMIN — fill in the identifier/password from createFirstAdmin.js output
# @name adminLogin
POST {{baseUrl}}/login
Content-Type: application/json

{
  "identifier": "ADM-2026-0001",
  "password": "REPLACE_WITH_ADMIN_TEMP_PASSWORD",
  "role": "admin"
}

###
@adminToken = {{adminLogin.response.body.accessToken}}

### 2. Create a doctor (admin-only) — grab the returned identifier + tempPassword
# @name createDoctor
POST {{baseUrl}}/staff
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "fullName": "Dr. Test Doctor",
  "role": "doctor",
  "phone": "9800000000",
  "department": "Cardiology",
  "specialization": "Cardiologist"
}

###
### 3. Register a PATIENT
# @name registerPatient
POST {{baseUrl}}/register
Content-Type: application/json

{
  "fullName": "Test Patient",
  "email": "testpatient@example.com",
  "password": "password123",
  "phone": "9811111111",
  "dob": "1995-05-20",
  "bloodGroup": "O+"
}

###
### 4. Log in as the DOCTOR — use the identifier + tempPassword printed by step 2
# @name doctorLogin
POST {{baseUrl}}/login
Content-Type: application/json

{
  "identifier": "REPLACE_WITH_DOCTOR_IDENTIFIER_FROM_STEP_2",
  "password": "REPLACE_WITH_DOCTOR_TEMP_PASSWORD_FROM_STEP_2",
  "role": "doctor"
}

###
@doctorToken = {{doctorLogin.response.body.accessToken}}
@doctorId = {{doctorLogin.response.body.user.id}}

### 5. Doctor sets weekly availability — Monday(1) 09:00-13:00, 30-min slots
POST {{baseUrl}}/doctors/availability
Content-Type: application/json
Authorization: Bearer {{doctorToken}}

{
  "dayOfWeek": 1,
  "startTime": "09:00",
  "endTime": "13:00",
  "slotDurationMinutes": 30
}

###
### 6. Log in as the PATIENT
# @name patientLogin
POST {{baseUrl}}/login
Content-Type: application/json

{
  "identifier": "testpatient@example.com",
  "password": "password123",
  "role": "patient"
}

###
@patientToken = {{patientLogin.response.body.accessToken}}

### 7. Patient browses doctors
GET {{baseUrl}}/appointments/doctors
Authorization: Bearer {{patientToken}}

###
### 8. Patient checks a doctor's open slots for a date
### NOTE: pick a date that falls on the same weekday as the availability above (e.g. next Monday)
GET {{baseUrl}}/doctors/{{doctorId}}/slots?date=2026-07-06
Authorization: Bearer {{patientToken}}

###
### 9. Patient books an appointment — use a slot returned by step 8
# @name bookAppointment
POST {{baseUrl}}/appointments
Content-Type: application/json
Authorization: Bearer {{patientToken}}

{
  "doctorId": "{{doctorId}}",
  "appointmentDate": "2026-07-06",
  "startTime": "09:00",
  "reason": "Routine checkup"
}

###
@appointmentId = {{bookAppointment.response.body.appointment.id}}

### 10. Doctor sees the new appointment
GET {{baseUrl}}/appointments
Authorization: Bearer {{doctorToken}}

###
### 11. Doctor confirms it
PATCH {{baseUrl}}/appointments/{{appointmentId}}/status
Content-Type: application/json
Authorization: Bearer {{doctorToken}}

{
  "status": "confirmed"
}

###
### 12. Patient sees it's confirmed
GET {{baseUrl}}/appointments
Authorization: Bearer {{patientToken}}

###
### 13. (Optional) Patient tries to book the SAME slot again — should get 409 Conflict
POST {{baseUrl}}/appointments
Content-Type: application/json
Authorization: Bearer {{patientToken}}

{
  "doctorId": "{{doctorId}}",
  "appointmentDate": "2026-07-06",
  "startTime": "09:00",
  "reason": "Duplicate test"
}
